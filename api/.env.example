# Yerel geliştirme: kopyalayıp .env yapın ( .env asla commit edilmez )
# cp .env.example .env

# PostgreSQL — yerel Docker örneği:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kpss_ai_tarih?schema=public"

# Railway: DATABASE_URL’i repoya yazmayın. Railway → servis → Variables içinde
# PostgreSQL eklentisinden gelen ${DATABASE_URL} veya "Reference" ile bağlayın.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Railway genelde PORT’u otomatik verir; kod process.env.PORT kullanır.
# PORT=3000
