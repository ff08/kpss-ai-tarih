generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Topic {
  id                    Int                    @id @default(autoincrement())
  title                 String
  /// Ana sayfada konu başlığının altındaki kısa açıklama
  description           String?
  sortOrder             Int                    @default(0)
  subtopics             Subtopic[]
  informationContents   InformationContent[]
  openQaContents        OpenQaContent[]
  mcqContents           McqContent[]
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model Subtopic {
  id                  Int                    @id @default(autoincrement())
  topicId             Int
  topic               Topic                  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title               String
  sortOrder           Int                    @default(0)
  informationContents InformationContent[]
  openQaContents      OpenQaContent[]
  mcqContents         McqContent[]

  @@index([topicId])
}

/// Bilgi kartları (INFORMATION)
model InformationContent {
  id         Int      @id @default(autoincrement())
  topicId    Int
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId Int
  subtopic   Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  tag        String?
  createdAt  DateTime @default(now())

  @@index([subtopicId])
  @@index([topicId])
  @@index([subtopicId, topicId])
}

/// Soru–cevap kartları (OPEN_QA)
model OpenQaContent {
  id         Int      @id @default(autoincrement())
  topicId    Int
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId Int
  subtopic   Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  tag        String?
  /// Soru yüzündeki kısa ipucu metni
  hint       String?
  createdAt  DateTime @default(now())

  @@index([subtopicId])
  @@index([topicId])
  @@index([subtopicId, topicId])
}

/// Çoktan seçmeli kartlar (MCQ); `content` JSON şeklinde seçenekler
model McqContent {
  id         Int                @id @default(autoincrement())
  topicId    Int
  topic      Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId Int
  subtopic   Subtopic           @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  difficulty QuestionDifficulty
  title      String
  content    String             @db.Text
  tag        String?
  createdAt  DateTime           @default(now())

  @@index([subtopicId])
  @@index([topicId])
  @@index([subtopicId, topicId])
}
