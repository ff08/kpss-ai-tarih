generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tarih dersi müfredat kovası (KPSS, YKS, LGS, e-YDS …). İçerik konuları `examId` ile buna bağlanır.
model ExamCatalog {
  id          Int      @id @default(autoincrement())
  /// API / istemci için sabit anahtar (örn. kpss_lisans_tarih)
  slug        String   @unique
  label       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  topics      Topic[]
  users       User[]
  rankDefs    ExamRankDef[]

  @@map("exam_catalog")
}

/// Sınav bazlı rütbe (mühür) seviyeleri; görsel URL isteğe bağlı, istemci yedek sabitleri kullanır.
model ExamRankDef {
  id          Int         @id @default(autoincrement())
  examId      Int
  exam        ExamCatalog @relation(fields: [examId], references: [id], onDelete: Cascade)
  /// 1..N (KPSS Tarih için 23)
  level       Int
  title       String
  /// Rütbe kısa açıklama / karakteristik
  description String?     @db.Text
  imageUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([examId, level])
  @@index([examId])
  @@map("exam_rank_defs")
}

model Topic {
  id                    Int                    @id @default(autoincrement())
  examId                Int
  exam                  ExamCatalog            @relation(fields: [examId], references: [id], onDelete: Restrict)
  title                 String
  /// Ana sayfada konu başlığının altındaki kısa açıklama
  description           String?
  sortOrder             Int                    @default(0)
  subtopics             Subtopic[]
  informationContents   InformationContent[]
  openQaContents        OpenQaContent[]
  wordGameContents      WordGameContent[]
  mcqContents           McqContent[]
  contentIssueReports   ContentIssueReport[]

  @@index([examId])
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model Subtopic {
  id                  Int                    @id @default(autoincrement())
  topicId             Int
  topic               Topic                  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title               String
  /// Konu ekranı alt konu kartı açıklaması (opsiyonel).
  description         String?                @db.Text
  sortOrder           Int                    @default(0)
  informationContents InformationContent[]
  openQaContents      OpenQaContent[]
  wordGameContents    WordGameContent[]
  mcqContents         McqContent[]
  contentIssueReports   ContentIssueReport[]

  @@index([topicId])
}

/// Bilgi kartları (INFORMATION)
model InformationContent {
  id         Int      @id @default(autoincrement())
  topicId    Int
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId Int
  subtopic   Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  tag        String?
  /// Kart üstünde resim göstermek için (opsiyonel).
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now())

  @@index([subtopicId])
  @@index([topicId])
  @@index([subtopicId, topicId])
}

/// Soru–cevap kartları (OPEN_QA)
model OpenQaContent {
  id         Int      @id @default(autoincrement())
  topicId    Int
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId Int
  subtopic   Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  tag        String?
  /// Soru yüzündeki kısa ipucu metni
  hint       String?
  createdAt  DateTime @default(now())

  @@index([subtopicId])
  @@index([topicId])
  @@index([subtopicId, topicId])
}

/// Kelime oyunu kartları (WORD_GAME)
model WordGameContent {
  id         Int      @id @default(autoincrement())
  topicId    Int
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId Int
  subtopic   Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  question   String
  answer     String
  hint       String?
  tag        String?
  createdAt  DateTime @default(now())

  @@index([subtopicId])
  @@index([topicId])
  @@index([subtopicId, topicId])
}

/// Çoktan seçmeli kartlar (MCQ); `content` JSON şeklinde seçenekler
model McqContent {
  id         Int                @id @default(autoincrement())
  topicId    Int
  topic      Topic              @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId Int
  subtopic   Subtopic           @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  difficulty QuestionDifficulty
  title      String
  content    String             @db.Text
  explanation String?           @db.Text
  tag        String?
  createdAt  DateTime           @default(now())

  @@index([subtopicId])
  @@index([topicId])
  @@index([subtopicId, topicId])
}

/// Hangi içerik tablosuna ait olduğu `datasetKind` + `contentRowId` ile belirlenir (ID'ler tablolar arası çakışabilir).
enum ContentDatasetKind {
  INFORMATION
  OPEN_QA
  MCQ
  WORD_GAME
}

enum ContentIssueCategory {
  WRONG_INFO
  CONFLICTING_INFO
  MISSING_INFO
}

/// İnceleme / veri temizliği kuyruğu için durum
enum ContentIssueStatus {
  OPEN
  REVIEWED
  FIXED
  IGNORED
}

model ContentIssueReport {
  id                    Int                  @id @default(autoincrement())
  topicId               Int
  topic                 Topic                @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subtopicId            Int
  subtopic              Subtopic             @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  datasetKind           ContentDatasetKind
  /// İlgili tablodaki satır kimliği (InformationContent / OpenQaContent / McqContent)
  contentRowId          Int
  category              ContentIssueCategory
  note                  String?              @db.Text
  topicTitleSnapshot    String?
  subtopicTitleSnapshot String?
  cardTitleSnapshot     String?              @db.VarChar(512)
  /// Uygulama tarafında üretilen kalıcı istemci kimliği (aynı cihazdan aynı karta tekrar bildirimi engellemek için)
  reporterClientId    String?
  status                ContentIssueStatus   @default(OPEN)
  createdAt             DateTime             @default(now())

  @@index([topicId])
  @@index([subtopicId])
  @@index([datasetKind, contentRowId])
  @@index([status, createdAt])
  @@index([createdAt])
  @@unique([reporterClientId, subtopicId, datasetKind, contentRowId])
}

// —— Kullanıcı / oturum / abonelik (Tarih AI) ——

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  guestClientId String?        @unique
  displayName   String?
  /// @deprecated Yeni alan: selectedExamId. Eski istemciler için tutulur.
  examTargetId  String?
  selectedExamId Int?
  selectedExam   ExamCatalog? @relation(fields: [selectedExamId], references: [id], onDelete: SetNull)
  isGuest       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  subscriptions Subscription[]

  @@index([selectedExamId])
  @@map("users")
}

model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailOtpChallenge {
  id        Int      @id @default(autoincrement())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("email_otp_challenges")
}

enum AppLogLevel {
  INFO
  WARN
  ERROR
}

model AppLog {
  id        Int         @id @default(autoincrement())
  level     AppLogLevel @default(INFO)
  action    String
  userId    String?
  meta      Json?
  createdAt DateTime    @default(now())

  @@index([createdAt])
  @@index([action])
  @@map("app_logs")
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

/// Ödeme sağlayıcı entegrasyonu sonrası doldurulacak; şema hazır.
model Subscription {
  id               Int                @id @default(autoincrement())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             SubscriptionPlan
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?
  provider         String?
  externalId       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status])
  @@map("subscriptions")
}
